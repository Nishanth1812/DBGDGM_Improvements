# DBGDGM Improvements — .gitignore
# ─────────────────────────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*.pyo
.Python
.venv/
venv/
*.egg-info/
dist/
build/

# Data and checkpoints — use rsync to transfer to droplet
Alzhiemers_Training/data/
Alzhiemers_Training/models/

# Training outputs (synced via rsync, not git)
models_*/
local_results/
logs/
*.log

# Processed dataset cache (large binary — tracked via Git LFS if committed)
# Uncomment to ignore pkl cache entirely:
# *.pkl

# Jupyter
.ipynb_checkpoints/
*.ipynb

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
